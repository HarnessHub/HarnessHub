{
  "name": "clawpack",
  "version": "0.1.0",
  "description": "Application-layer packaging and distribution tool for OpenClaw agents",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "clawpack": "dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "pm": "node scripts/codex-pm.mjs",
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "review:checkpoint": "./scripts/run-codex-review-checkpoint.sh",
    "preflight": "./scripts/run-agent-preflight.sh",
    "smoke": "./scripts/run-cli-smoke.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "openclaw",
    "agent",
    "packaging",
    "distribution",
    "cli",
    "ai-agent",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mrxuexi/clawpack.git"
  },
  "homepage": "https://github.com/Mrxuexi/clawpack#readme",
  "bugs": {
    "url": "https://github.com/Mrxuexi/clawpack/issues"
  },
  "author": "Mrxuexi",
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "commander": "^13.1.0",
    "json5": "^2.2.3",
    "tar": "^7.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
